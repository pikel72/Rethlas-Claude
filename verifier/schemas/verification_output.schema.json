{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VerificationOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verification_report",
    "verdict",
    "repair_hints"
  ],
  "properties": {
    "verification_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "critical_errors",
        "gaps"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "critical_errors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "gaps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "notes": {
          "type": "string"
        },
        "checked_items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "external_reference_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "correct",
        "wrong"
      ]
    },
    "repair_hints": {
      "type": "string"
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "location",
        "issue"
      ],
      "properties": {
        "location": {
          "type": "string",
          "minLength": 1
        },
        "issue": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        }
      }
    }
  }
}
